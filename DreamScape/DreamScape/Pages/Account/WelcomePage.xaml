<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Account.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Account"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <TextBlock Text="Welcome to DreamScape" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
            <Button x:Name="LoginButton" Content="Login" HorizontalAlignment="Stretch" Click="LoginButton_Click" />
            <Button x:Name="CreateAccountButton" Content="Create Account" HorizontalAlignment="Stretch" Click="CreateAccountButton_Click" />
        </StackPanel>
    </Grid>
</Page>
