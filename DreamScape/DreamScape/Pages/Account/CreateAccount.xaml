<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Account.CreateAccount"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Account"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Width="320">
            <TextBlock Text="Create Account" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />

            <TextBlock Text="Username" />
            <TextBox x:Name="UsernameTextBox" PlaceholderText="Enter your username" />

            <TextBlock Text="Password" />
            <PasswordBox x:Name="PasswordInput" PlaceholderText="Enter your password" />

            <TextBlock x:Name="ErrorsTextblock" Foreground="Red" TextWrapping="Wrap" />
            <TextBlock x:Name="SuccessTextblock" Foreground="Green" TextWrapping="Wrap" />

            <Button x:Name="SaveButton" Content="Create Account" HorizontalAlignment="Stretch" Click="SaveButton_Click" />
            <Button x:Name="BackButton" Content="Back" HorizontalAlignment="Stretch" Click="BackButton_Click" />
        </StackPanel>
    </Grid>
</Page>
