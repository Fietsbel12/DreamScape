<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Account.CreateAccount"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Account"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Width="320">
            <TextBlock Text="Account aanmaken" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />

            <TextBlock Text="Gebruikersnaam" />
            <TextBox x:Name="NaamTextBox" PlaceholderText="Voer je gebruikersnaam in" />

            <TextBlock Text="Wachtwoord" />
            <PasswordBox x:Name="WachtwoordPasswordBox" PlaceholderText="Voer je wachtwoord in" />

            <TextBlock x:Name="ErrorsTextblock" Foreground="Red" TextWrapping="Wrap" />
            <TextBlock x:Name="SuccessTextblock" Foreground="Green" TextWrapping="Wrap" />

            <Button x:Name="OpslaanButton" Content="Account aanmaken" HorizontalAlignment="Stretch" Click="OpslaanButton_Click" />
            <Button x:Name="backButton" Content="Terug" HorizontalAlignment="Stretch" Click="backButton_Click" />
        </StackPanel>
    </Grid>
</Page>
