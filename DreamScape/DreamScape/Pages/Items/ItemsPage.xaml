<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Items.ItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Items"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,0,0,16">

            <ComboBox x:Name="TypeFilter"
                      Header="Type"
                      Width="140"
                      SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Weapon"/>
                <ComboBoxItem Content="Armor"/>
            </ComboBox>

            <ComboBox x:Name="RarityFilter"
                      Header="Rarity"
                      Width="140"
                      SelectionChanged="Filter_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Common"/>
                <ComboBoxItem Content="Uncommon"/>
                <ComboBoxItem Content="Rare"/>
                <ComboBoxItem Content="Legendary"/>
            </ComboBox>

        </StackPanel>

        <!-- Items list -->
        <ListView Grid.Row="1"
                  x:Name="ItemsListView"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       FontSize="16"/>
                            <TextBlock Text="{Binding Description}"
                                       Opacity="0.7"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                <TextBlock FontSize="12" Opacity="0.8">
                                    <Run Text="STR "/><Run Text="{Binding Strength}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Opacity="0.8">
                                    <Run Text="SPD "/><Run Text="{Binding Speed}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Opacity="0.8">
                                    <Run Text="DUR "/><Run Text="{Binding Durability}"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Opacity="0.8">
                                    <Run Text="Magic: "/><Run Text="{Binding MagicalProperty}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Type}"
                                       FontSize="12"
                                       Opacity="0.7"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding Rarity}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
