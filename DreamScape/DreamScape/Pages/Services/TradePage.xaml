<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Services.TradeService"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Services"
    xmlns:localData="using:DreamScape.Data"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   x:Name="WelcomeText"
                   Text="Dashboard"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <!-- Two-column layout: Trades (left) | Inventory (right) -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left column: Pending Trades -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Pending Trades"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <ListView Grid.Row="1"
                          x:Name="TradesListView"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="localData:Trade">
                            <Grid Padding="8,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind Sender.Username}"
                                           VerticalAlignment="Center"
                                           FontSize="14"/>
                                <Button Grid.Column="1"
                                        Content="Accept"
                                        Tag="{x:Bind TradeId}"
                                        Click="AcceptButton_Click"
                                        Background="Green"
                                        Foreground="White"
                                        Padding="10,4"/>
                                <Button Grid.Column="2"
                                        Content="Decline"
                                        Tag="{x:Bind TradeId}"
                                        Click="DeclineButton_Click"
                                        Background="DarkRed"
                                        Foreground="White"
                                        Padding="10,4"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2"
                        Content="Create Trade"
                        Click="CreateTradeButton_Click"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"/>
            </Grid>

            <!-- Right column: My Inventory -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="My Inventory"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <ListView Grid.Row="1"
                          x:Name="InventoryListView"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="localData:InventoryItem">
                            <StackPanel Orientation="Horizontal" Spacing="12" Padding="8,6">
                                <TextBlock Text="{x:Bind Item.Name}"
                                           Width="160"
                                           FontSize="14"/>
                                <TextBlock Text="x"
                                           FontSize="14"
                                           Foreground="Gray"/>
                                <TextBlock Text="{x:Bind Quantity}"
                                           FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
