<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Services.TradeService"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Services"
    xmlns:localData="using:DreamScape.Data"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
           Text="Trade Request"
           FontSize="24"
           FontWeight="Bold"
           Foreground="Black"
           Margin="0,0,0,16"/>

        <ListView Grid.Row="1"
                  x:Name="TradesListView">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="localData:Trade">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{x:Bind Sender.Username}" Width="120" />
                        <TextBlock Text="Status:" Margin="20,0,0,0"/>
                        <TextBlock Text="{x:Bind Status}" Width="120"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
            <Button x:Name="AcceptButton" 
                        Content="Accept" 
                        Click="AcceptButton_Click" 
                        Background="Black"/>
            <Button x:Name="DeclineButton" 
                        Content="Decline" 
                        Click="DeclineButton_Click" 
                        Background="Black" />
        </StackPanel>
    </Grid>
</Page>
