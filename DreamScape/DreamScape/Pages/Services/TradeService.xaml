<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.Services.TradeService"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Incoming trade requests -->
        <TextBlock Grid.Row="0"
                   Text="Incoming Trade Requests"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <ListView Grid.Row="1"
                  x:Name="TradeListView"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" FontSize="15">
                                <Run Text="From: "/><Run Text="{Binding Sender.Username}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding OfferedItemsSummary}"
                                       Opacity="0.7"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Content="Accept"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="{Binding TradeId}"
                                    Click="AcceptButton_Click"/>
                            <Button Content="Decline"
                                    Tag="{Binding TradeId}"
                                    Click="DeclineButton_Click"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2"
                   Text="Send a Trade Request"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,20,0,12"/>

        <!-- Send trade form -->
        <StackPanel Grid.Row="3" Spacing="12">

            <ComboBox x:Name="ReceiverComboBox"
                      Header="Send to player"
                      HorizontalAlignment="Stretch"/>

            <ComboBox x:Name="ItemComboBox"
                      Header="Item to offer"
                      HorizontalAlignment="Stretch"/>

            <Button x:Name="SendTradeButton"
                    Content="Send Trade Request"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SendTradeButton_Click"/>

        </StackPanel>

    </Grid>
</Page>

