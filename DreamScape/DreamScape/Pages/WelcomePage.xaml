<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScape.Pages.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScape.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Center content: title and buttons -->
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="32">

            <TextBlock Text="Welcome to DreamScape"
                       FontSize="40"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="24">

                <Button x:Name="LoginButton"
                        Content="Login"
                        Width="150"
                        Height="48"
                        Click="LoginButton_Click" />

                <Button x:Name="CreateAccountButton"
                        Content="Create Account"
                        Width="150"
                        Height="48"
                        Click="CreateAccountButton_Click" />

            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="1"
                   Text="Created by Lotus :3"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16" />
    </Grid>
</Page>
